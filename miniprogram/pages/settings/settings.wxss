/* pages/settings/settings.wxss */
.page {
  background: #0d1117;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 28rpx 12rpx;
}
.section-icon { font-size: 28rpx; }
.section-title {
  font-size: 26rpx;
  color: #e6edf3;
  font-weight: 600;
}

/* Card */
.card {
  background: #161b22;
  border: 1rpx solid #30363d;
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
}

/* Form */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 24rpx;
  color: #8b949e;
  display: block;
  margin-bottom: 12rpx;
}
.form-input {
  background: #0d1117;
  border: 1rpx solid #30363d;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #e6edf3;
}
.form-hint {
  font-size: 20rpx;
  color: #8b949e;
  margin-top: 8rpx;
  display: block;
}

/* Buttons */
.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}
.btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.btn-primary {
  background: #238636;
  color: #fff;
  border: 1rpx solid #2ea043;
}
.btn-secondary {
  background: rgba(88,166,255,0.1);
  color: #58a6ff;
  border: 1rpx solid rgba(88,166,255,0.3);
}

/* Status */
.status-line {
  margin-top: 16rpx;
}
.status-text {
  font-size: 22rpx;
  color: #8b949e;
}

/* Sources */
.sources-list {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #30363d;
}
.sources-title {
  font-size: 22rpx;
  color: #8b949e;
  margin-bottom: 12rpx;
  display: block;
}
.source-tag {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 22rpx;
  color: #e6edf3;
}
.source-status {
  font-size: 18rpx;
  color: #8b949e;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(139,148,158,0.1);
}
.source-status.ok {
  color: #3fb950;
  background: rgba(63,185,80,0.1);
}

/* Setting Row */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(48,54,61,0.5);
}
.setting-row:last-child { border-bottom: none; }
.setting-label {
  font-size: 26rpx;
  color: #e6edf3;
}
.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #58a6ff;
  font-variant-numeric: tabular-nums;
}
.picker-arrow {
  font-size: 28rpx;
  color: #8b949e;
}

/* Toggle */
.toggle {
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #30363d;
  position: relative;
  transition: background 0.3s;
}
.toggle.on {
  background: #238636;
}
.toggle-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.3s;
}
.toggle.on .toggle-dot {
  left: 44rpx;
}

/* Help */
.help-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.help-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(88,166,255,0.12);
  color: #58a6ff;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  line-height: 40rpx;
  flex-shrink: 0;
}
.help-text {
  font-size: 24rpx;
  color: #8b949e;
  line-height: 1.7;
  flex: 1;
}
.code {
  background: rgba(88,166,255,0.1);
  color: #58a6ff;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-family: monospace;
}
.copy-btn {
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(88,166,255,0.08);
  border: 1rpx solid rgba(88,166,255,0.2);
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #58a6ff;
}

/* About */
.about {
  text-align: center;
  padding: 40rpx 0 20rpx;
}
.about-text {
  font-size: 22rpx;
  color: #8b949e;
  display: block;
}
.about-sub {
  font-size: 18rpx;
  color: #484f58;
  display: block;
  margin-top: 8rpx;
}
