<!-- pages/index/index.wxml -->
<view class="page">

  <!-- Header -->
  <view class="header">
    <view class="header-left">
      <text class="logo">贵金属行情监控</text>
    </view>
    <view class="header-right">
      <text class="update-time">{{lastUpdate}}</text>
      <view class="refresh-btn {{loading ? 'spinning' : ''}}" bindtap="onRefresh">
        <text class="refresh-icon">⟳</text>
      </view>
    </view>
  </view>

  <!-- Data Source Badge -->
  <view class="source-bar" wx:if="{{activeSources.length > 0}}">
    <view class="live-dot"></view>
    <text class="source-text">实时 · {{sourceSummary}}</text>
  </view>
  <view class="source-bar" wx:else>
    <text class="source-text demo">演示模式（需配置服务器地址）</text>
  </view>

  <!-- Tab Bar -->
  <view class="tab-bar">
    <view class="tab-btn {{activeTab === 'silver' ? 'active-silver' : ''}}" data-tab="silver" bindtap="switchTab">
      <text>白银</text>
    </view>
    <view class="tab-btn {{activeTab === 'gold' ? 'active-gold' : ''}}" data-tab="gold" bindtap="switchTab">
      <text>黄金</text>
    </view>
  </view>

  <block wx:if="{{activeTab === 'silver'}}">
    <view class="price-row">
      <view class="price-card card-hu">
        <view class="card-header">
          <text class="card-label">沪银主力</text>
          <view class="tag tag-hu">AG</view>
        </view>
        <view class="price-main">{{hu.price}}</view>
        <view class="price-unit">元 / 千克</view>
        <view class="price-change">
          <text class="{{hu.change >= 0 ? 'text-red' : 'text-green'}}">{{hu.change}}</text>
          <text class="{{hu.changePct >= 0 ? 'text-red' : 'text-green'}} chg-pct">{{hu.changePct}}</text>
        </view>
        <view class="mini-stats">
          <view class="mini-stat"><text class="stat-label">开</text><text class="stat-val">{{hu.open}}</text></view>
          <view class="mini-stat"><text class="stat-label">高</text><text class="stat-val text-red">{{hu.high}}</text></view>
          <view class="mini-stat"><text class="stat-label">低</text><text class="stat-val text-green">{{hu.low}}</text></view>
        </view>
      </view>

      <view class="price-card card-comex">
        <view class="card-header">
          <text class="card-label">COMEX 银</text>
          <view class="tag tag-comex">XAG</view>
        </view>
        <view class="price-main">{{comex.price}}</view>
        <view class="price-unit">美元 / 盎司</view>
        <view class="price-change">
          <text class="{{comex.change >= 0 ? 'text-red' : 'text-green'}}">{{comex.change}}</text>
          <text class="{{comex.changePct >= 0 ? 'text-red' : 'text-green'}} chg-pct">{{comex.changePct}}</text>
        </view>
        <view class="mini-stats">
          <view class="mini-stat"><text class="stat-label">开</text><text class="stat-val">{{comex.open}}</text></view>
          <view class="mini-stat"><text class="stat-label">高</text><text class="stat-val text-red">{{comex.high}}</text></view>
          <view class="mini-stat"><text class="stat-label">低</text><text class="stat-val text-green">{{comex.low}}</text></view>
        </view>
      </view>
    </view>

    <view class="spread-card">
      <view class="spread-row">
        <view class="spread-item">
          <text class="spread-label">比价</text>
          <text class="spread-value text-yellow">{{spread.ratio}}</text>
        </view>
        <view class="spread-item">
          <text class="spread-label">价差</text>
          <text class="spread-value {{spread.statusType === 'up' ? 'text-red' : spread.statusType === 'dn' ? 'text-green' : 'text-yellow'}}">{{spread.cnySpread}} 元/kg</text>
        </view>
        <view class="spread-item">
          <text class="spread-label">状态</text>
          <view class="status-chip {{spread.statusType}}">{{spread.status}}</view>
        </view>
        <view class="spread-item">
          <text class="spread-label">USD/CNY</text>
          <text class="spread-value">{{spread.usdCny}}</text>
        </view>
      </view>
    </view>

    <view class="section-title">
      <text class="section-text">波动率指标</text>
    </view>
    <view class="vol-row">
      <view class="vol-card">
        <view class="vol-top">
          <text class="vol-label">沪银 HV20</text>
          <text class="vol-value text-hu">{{hv.hu}}</text>
        </view>
        <view class="vol-bar-wrap">
          <view class="vol-bar bar-hu" style="width: {{hv.hu === '--' ? '0' : (parseFloat(hv.hu) / 40 * 100) + '%'}}"></view>
        </view>
      </view>
      <view class="vol-card">
        <view class="vol-top">
          <text class="vol-label">COMEX HV20</text>
          <text class="vol-value text-comex">{{hv.comex}}</text>
        </view>
        <view class="vol-bar-wrap">
          <view class="vol-bar bar-comex" style="width: {{hv.comex === '--' ? '0' : (parseFloat(hv.comex) / 60 * 100) + '%'}}"></view>
        </view>
      </view>
    </view>

    <view class="alert-entry" bindtap="goAlerts">
      <view class="alert-entry-left">
        <text class="alert-icon">🔔</text>
        <text class="alert-entry-text">3-Tick 预警监控</text>
      </view>
      <view class="alert-entry-right">
        <text class="alert-threshold">阈值 ≥1%</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="info-notice">
      <text class="info-icon">ℹ️</text>
      <text class="info-text">白银视图：沪银主力与 COMEX 银实时联动展示，数据来自 Sina + akshare 缓存。</text>
    </view>
  </block>

  <block wx:else>
    <view class="price-row">
      <view class="price-card card-au">
        <view class="card-header">
          <text class="card-label">沪金主力</text>
          <view class="tag tag-au">AU</view>
        </view>
        <view class="price-main">{{au.price}}</view>
        <view class="price-unit">元 / 克</view>
        <view class="price-change">
          <text class="{{au.change >= 0 ? 'text-red' : 'text-green'}}">{{au.change}}</text>
          <text class="{{au.changePct >= 0 ? 'text-red' : 'text-green'}} chg-pct">{{au.changePct}}</text>
        </view>
        <view class="mini-stats">
          <view class="mini-stat"><text class="stat-label">开</text><text class="stat-val">{{au.open}}</text></view>
          <view class="mini-stat"><text class="stat-label">高</text><text class="stat-val text-red">{{au.high}}</text></view>
          <view class="mini-stat"><text class="stat-label">低</text><text class="stat-val text-green">{{au.low}}</text></view>
        </view>
      </view>

      <view class="price-card card-gold-comex">
        <view class="card-header">
          <text class="card-label">COMEX 金</text>
          <view class="tag tag-gold-comex">XAU</view>
        </view>
        <view class="price-main">{{comexGold.price}}</view>
        <view class="price-unit">美元 / 盎司</view>
        <view class="price-change">
          <text class="{{comexGold.change >= 0 ? 'text-red' : 'text-green'}}">{{comexGold.change}}</text>
          <text class="{{comexGold.changePct >= 0 ? 'text-red' : 'text-green'}} chg-pct">{{comexGold.changePct}}</text>
        </view>
        <view class="mini-stats">
          <view class="mini-stat"><text class="stat-label">开</text><text class="stat-val">{{comexGold.open}}</text></view>
          <view class="mini-stat"><text class="stat-label">高</text><text class="stat-val text-red">{{comexGold.high}}</text></view>
          <view class="mini-stat"><text class="stat-label">低</text><text class="stat-val text-green">{{comexGold.low}}</text></view>
        </view>
      </view>
    </view>

    <view class="spread-card">
      <view class="spread-row">
        <view class="spread-item">
          <text class="spread-label">比价</text>
          <text class="spread-value text-yellow">{{goldSpread.ratio}}</text>
        </view>
        <view class="spread-item">
          <text class="spread-label">价差</text>
          <text class="spread-value {{goldSpread.statusType === 'up' ? 'text-red' : goldSpread.statusType === 'dn' ? 'text-green' : 'text-yellow'}}">{{goldSpread.cnySpread}} 元/克</text>
        </view>
        <view class="spread-item">
          <text class="spread-label">状态</text>
          <view class="status-chip {{goldSpread.statusType}}">{{goldSpread.status}}</view>
        </view>
        <view class="spread-item">
          <text class="spread-label">USD/CNY</text>
          <text class="spread-value">{{goldSpread.usdCny}}</text>
        </view>
      </view>
    </view>

    <view class="section-title">
      <text class="section-text">波动率指标</text>
    </view>
    <view class="vol-row">
      <view class="vol-card">
        <view class="vol-top">
          <text class="vol-label">沪金 HV20</text>
          <text class="vol-value text-au">{{hv.au}}</text>
        </view>
        <view class="vol-bar-wrap">
          <view class="vol-bar bar-au" style="width: {{hv.au === '--' ? '0' : (parseFloat(hv.au) / 30 * 100) + '%'}}"></view>
        </view>
      </view>
      <view class="vol-card">
        <view class="vol-top">
          <text class="vol-label">COMEX 金 HV20</text>
          <text class="vol-value text-gold-comex">{{hv.comexGold}}</text>
        </view>
        <view class="vol-bar-wrap">
          <view class="vol-bar bar-gold-comex" style="width: {{hv.comexGold === '--' ? '0' : (parseFloat(hv.comexGold) / 40 * 100) + '%'}}"></view>
        </view>
      </view>
    </view>

    <view class="alert-entry" bindtap="goAlerts">
      <view class="alert-entry-left">
        <text class="alert-icon">🔔</text>
        <text class="alert-entry-text">3-Tick 预警监控</text>
      </view>
      <view class="alert-entry-right">
        <text class="alert-threshold">阈值 ≥1%</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="info-notice">
      <text class="info-icon">ℹ️</text>
      <text class="info-text">黄金视图：沪金主力与 COMEX 金实时联动展示，支持与网页端一致的金银切换。</text>
    </view>
  </block>

</view>
